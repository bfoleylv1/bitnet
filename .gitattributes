* text=auto

# Shell scripts must use LF
*.sh text eol=lf
*.bash text eol=lf

# Python scripts can use auto but prefer LF
*.py text eol=lf

# Batch files can use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation
*.md text eol=lf
README* text eol=lf
QUICKSTART* text eol=lf

# Binary files
*.gguf binary
*.bin binary
*.so binary
*.dylib binary
*.dll binary
